<div class="analytics-page">
  <div class="overlay"></div>
  
  <header class="admin-header">
    <h1>Platform Analytics <span class="v-line">|</span> <small>Admin Dashboard</small></h1>
  </header>

  <div class="dashboard-grid">
    <div class="glass-card">
      <div class="card-header">
        <i class="icon-pie"></i>
        <h3>Genre Distribution</h3>
      </div>
      <div class="chart-container">
        <canvas *ngIf="pieChartData.labels?.length"
                baseChart
                [data]="pieChartData"
                [type]="pieChartType"
                [options]="chartOptions">
        </canvas>
        <div *ngIf="!pieChartData.labels?.length" class="loader">Accessing Database...</div>
      </div>
    </div>

    <div class="glass-card">
      <div class="card-header">
        <i class="icon-line"></i>
        <h3>User Activity Dynamics</h3>
      </div>
      <div class="chart-container">
        <canvas *ngIf="lineChartData.labels?.length"
                baseChart
                [data]="lineChartData"
                [type]="lineChartType"
                [options]="chartOptions">
        </canvas>
        <div *ngIf="!lineChartData.labels?.length" class="loader">Fetching Activity Logs...</div>
      </div>
    </div>
  </div>
</div>