$poster-w: 320px;
$poster-h: 480px;
$gap: 30px;
$speed: 60s; 

.landing-page {
  min-height: 100vh;
  background-color: #0a0a0a;
  color: #fff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  font-family: 'Segoe UI', system-ui, sans-serif;
}

.content-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  background: radial-gradient(circle at center, rgba(18, 18, 18, 0.7) 0%, rgba(10, 10, 10, 1) 80%);
}

.text-section {
  text-align: center;
  max-width: 900px;
}

.title {
  font-size: 4.2rem;
  font-weight: 800;
  margin-bottom: 1.5rem;
  .highlight { font-style: italic; opacity: 0.9; }
}

.subtitle {
  font-size: 1.3rem;
  color: #b0b0b0;
  margin-bottom: 3rem;
  max-width: 700px;
  margin-inline: auto;
}

.actions {
  display: flex;
  gap: 15px;
  justify-content: center;
  .btn {
    padding: 1.1rem 2.8rem;
    font-size: 1.1rem;
    font-weight: 700;
    border-radius: 12px;
    cursor: pointer;
    border: 2px solid #fff;
    &-primary { background: #fff; color: #000; }
    &-outline { background: transparent; color: #fff; }
    transition: transform 0.2s;
    &:hover { transform: scale(1.05); }
  }
}

.marquee-container {
  width: 100%;
  padding: 60px 0;
  position: relative;
  overflow: hidden;
  mask-image: linear-gradient(to right, transparent, #000 15%, #000 85%, transparent);
}

.posters-track {
  display: flex;
  gap: $gap;
  width: max-content;
  animation: scrollLeft $speed linear infinite;
}

.poster-card {
  width: $poster-w;
  height: $poster-h;
  border-radius: 24px;
  background: #1a1a1a;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 0 25px 50px rgba(0,0,0,0.9);
  border: 1px solid rgba(255,255,255,0.1);

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
}

@keyframes scrollLeft {
  0% { transform: translateX(0); }
  100% { transform: translateX(calc(-50% - (#{$gap} / 2))); }
}

.placeholder {
  animation: pulse 2s infinite ease-in-out;
}

@keyframes pulse {
  0%, 100% { background: #1a1a1a; }
  50% { background: #2a2a2a; }
}

// ========================
// СТИЛІ МОДАЛЬНИХ ВІКОН
// ========================

.modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(10px);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease-out;
}

.modal-box {
  background-color: #121212;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24px;
  padding: 40px;
  width: 100%;
  max-width: 450px;
  position: relative;
  box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8);
  animation: slideUp 0.3s ease-out;
  
  &.modal-lg { max-width: 650px; }

  h2 { font-size: 2rem; font-weight: 700; margin-bottom: 5px; color: #fff; }
  p { color: #a0a0a0; margin-bottom: 25px; font-size: 0.95rem; }
}

.close-btn {
  position: absolute;
  top: 25px;
  right: 25px;
  background: transparent;
  border: none;
  color: #888;
  font-size: 1.8rem;
  line-height: 1;
  cursor: pointer;
  transition: color 0.2s;
  &:hover { color: #fff; }
}

form { display: flex; flex-direction: column; }

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;

  @media (max-width: 600px) {
    grid-template-columns: 1fr;
    .col-span-2 { grid-column: auto; }
  }
}

.col-span-2 {
  grid-column: span 2;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 15px;

  label { font-size: 0.9rem; color: #ccc; font-weight: 500; }

  input {
    background-color: #1e1e1e;
    border: 1px solid #333;
    color: #fff;
    padding: 14px 16px;
    border-radius: 12px;
    font-size: 1rem;
    transition: all 0.2s;
    font-family: inherit;

    &:focus { outline: none; border-color: #fff; background-color: #252525; }
    &::placeholder { color: #666; }
    
    // Стилізація іконки календаря для input type="date"
    &::-webkit-calendar-picker-indicator {
      filter: invert(1);
      cursor: pointer;
    }
  }
}

.custom-select {
  background-color: #1e1e1e;
  border: 1px solid #333;
  color: #fff;
  padding: 14px 16px;
  border-radius: 12px;
  font-size: 1rem;
  width: 100%;
  appearance: none;
  cursor: pointer;
  &:focus { outline: none; border-color: #fff; background-color: #252525; }
  option { background-color: #1e1e1e; color: #fff; }
}

.btn-submit {
  background-color: #fff;
  color: #000;
  border: none;
  padding: 15px;
  font-size: 1.1rem;
  font-weight: 700;
  border-radius: 12px;
  cursor: pointer;
  transition: background-color 0.2s, transform 0.2s;
  &:hover { background-color: #e0e0e0; transform: translateY(-2px); }
  &:disabled { background-color: #555; color: #888; cursor: not-allowed; transform: none; }
}

.modal-footer {
  margin-top: 25px;
  text-align: center;
  color: #888;
  font-size: 0.95rem;

  a {
    color: #fff;
    font-weight: 600;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 4px;
    &:hover { color: #ccc; }
  }
}

// --- ІНДИКАТОР КРОКІВ ---
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 35px;
  font-size: 0.85rem;
  font-weight: 600;
  color: #555;

  span { transition: color 0.3s; &.active { color: #fff; } }

  .line {
    height: 2px;
    width: 50px;
    background: #333;
    margin: 0 15px;
    transition: background 0.3s;
    &.active { background: #fff; }
    
    @media (max-width: 500px) { width: 20px; margin: 0 10px; }
  }
}

.modal-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 35px;
  gap: 15px;
  
  .btn { flex: 1; padding: 14px; border-radius: 12px; }
  .btn-outline { background: transparent; border: 1px solid #555; color: #fff; font-weight: 600; cursor: pointer; transition: all 0.2s; &:hover { border-color: #fff; background: rgba(255,255,255,0.05); } }
}

.w-100 { width: 100%; }
.mt-20 { margin-top: 20px; display: block; }

// --- ПРІОРИТЕТИ ---
.priority-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 20px;
}

.priority-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 24px;
  background: #1e1e1e;
  border: 1px solid #333;
  border-radius: 16px;
  cursor: pointer;
  transition: all 0.2s ease;

  &:hover { background: #252525; border-color: #555; }
  &.selected { background: rgba(255, 255, 255, 0.08); border-color: #fff; }

  .type-name { font-size: 1.15rem; font-weight: 600; color: #fff; }
  .add-icon { color: #666; font-size: 1.5rem; line-height: 1; font-weight: 300; }

  .rank-badge {
    background: #fff;
    color: #000;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-weight: 800;
    font-size: 1rem;
    box-shadow: 0 0 10px rgba(255,255,255,0.3);
  }
}

// --- ЧІПИ (Жанри / Мови) ---
.tastes-section label {
  color: #fff;
  font-weight: 600;
  margin-bottom: 12px;
  display: block;
  font-size: 1.05rem;
}

.chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.chip {
  padding: 10px 20px;
  background: #1e1e1e;
  border: 1px solid #444;
  border-radius: 30px;
  color: #ccc;
  cursor: pointer;
  transition: all 0.2s;
  user-select: none;
  font-weight: 500;

  &:hover { border-color: #888; color: #fff; background: #252525; }

  &.active {
    background: #fff;
    color: #000;
    border-color: #fff;
    font-weight: 700;
    box-shadow: 0 4px 10px rgba(255,255,255,0.2);
  }
}

// Анімації появи
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }