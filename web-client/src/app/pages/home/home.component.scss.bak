// Загальний контейнер (Темна тема)
.home-container {
  background-color: #1a1a1a;
  min-height: 100vh;
  color: white;
  padding-bottom: 50px;
  font-family: Arial, sans-serif;
}

/* =========================================
   НАВІГАЦІЯ (ХЕДЕР)
   ========================================= */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15px 50px;
  background-color: #141414;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  position: relative;
  z-index: 100;

  /* --- ЛІВА ЧАСТИНА --- */
  .nav-left {
    display: flex;
    align-items: center;
    gap: 40px;

    .logo { 
      font-size: 28px; 
      font-weight: bold;
      color: white;
      cursor: pointer;
    }

    .dropdown {
      position: relative;
      display: inline-block;

      .dropbtn {
        background-color: transparent;
        color: #e5e5e5;
        font-size: 16px;
        font-weight: bold;
        border: none;
        cursor: pointer;
        padding: 10px 0;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: color 0.2s;

        .arrow { font-size: 10px; transition: transform 0.2s; }
        &:hover { color: white; }
      }

      .dropdown-content {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        background-color: rgba(0, 0, 0, 0.9);
        min-width: 160px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 4px;
        box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.5);
        padding: 10px 0;

        a {
          color: #e5e5e5;
          padding: 10px 20px;
          text-decoration: none;
          display: block;
          font-size: 14px;
          font-weight: bold;
          cursor: pointer;
          transition: background 0.2s, color 0.2s;

          &:hover {
            background-color: rgba(255, 255, 255, 0.1);
            color: white;
          }
        }
      }

      &:hover .dropdown-content { display: block; }
      &:hover .arrow { transform: rotate(180deg); }
    }
  }

  /* --- ЦЕНТРАЛЬНА ЧАСТИНА (ІНПУТ ТА ДРОПДАУН ПОШУКУ) --- */
  .nav-center {
    flex-grow: 1;
    display: flex;
    justify-content: center;

    .search-container {
      position: relative; // Важливо для позиціонування результатів

      .search-bar input {
        width: 300px;
        padding: 10px 20px;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        outline: none;
        background-color: rgba(0, 0, 0, 0.5);
        color: white;
        font-size: 14px;
        transition: width 0.3s ease, border-color 0.3s ease, background-color 0.3s ease;

        &::placeholder { color: #888; }

        &:focus {
          width: 450px; // Зроблено трохи ширше
          background-color: rgba(0, 0, 0, 0.8);
          border-color: rgba(255, 255, 255, 0.5);
        }
      }

      /* Дропдаун із результатами пошуку */
      .search-dropdown {
        position: absolute;
        top: calc(100% + 10px);
        left: 0;
        width: 100%;
        background-color: #1e1e1e;
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.8);
        border: 1px solid #333;
        max-height: 400px;
        overflow-y: auto;
        z-index: 1000;

        &::-webkit-scrollbar { width: 8px; }
        &::-webkit-scrollbar-thumb { background: #444; border-radius: 4px; }

        .search-result-item {
          display: flex;
          align-items: center;
          padding: 10px 15px;
          cursor: pointer;
          border-bottom: 1px solid #2a2a2a;
          transition: background-color 0.2s;

          &:last-child { border-bottom: none; }
          &:hover { background-color: #333; }

          .search-thumb {
            width: 40px;
            height: 60px;
            object-fit: cover;
            border-radius: 4px;
            margin-right: 15px;
            background-color: #222;
          }

          .search-item-info {
            display: flex;
            flex-direction: column;

            .search-title {
              color: white;
              font-weight: bold;
              margin: 0 0 5px 0;
              font-size: 14px;
            }

            .search-meta {
              color: #888;
              font-size: 12px;
              margin: 0;
              text-transform: capitalize;
            }
          }
        }
      }
    }
  }

  /* --- ПРАВА ЧАСТИНА --- */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 15px;

    .btn-logout {
      background: transparent;
      color: #e5e5e5;
      border: none;
      font-size: 15px;
      font-weight: bold;
      cursor: pointer;
      transition: color 0.2s;
      &:hover { color: white; }
    }

    .avatar {
      width: 38px;
      height: 38px;
      background-color: #555;
      border-radius: 50%;
      cursor: pointer;
      border: 2px solid transparent;
      transition: border-color 0.2s;
      &:hover { border-color: white; }
    }
  }
}

/* =========================================
   СЕКЦІЇ З КОНТЕНТОМ (Існуючий CSS)
   ========================================= */
.content-section {
  margin-top: 40px;

  .section-title {
    text-align: center;
    font-style: italic;
    font-size: 40px;
    font-weight: bold;
    margin-bottom: 25px;
    color: white;
    width: 100%;
    display: block;
  }

  .row-container {
    display: flex;
    flex-direction: row;     
    flex-wrap: nowrap;       
    justify-content: flex-start;
    align-items: stretch;
    gap: 30px;               
    overflow-x: auto;        
    padding: 10px 60px 30px 60px; 
    width: 100%;
    box-sizing: border-box;
    
    &::-webkit-scrollbar { display: none; }
    -ms-overflow-style: none;  
    scrollbar-width: none;     
  }
}

/* =========================================
   ВЕЛИКА КАРТКА
   ========================================= */
.card {
  flex: 0 0 auto;          
  width: 280px;            
  background-color: white;
  color: black;
  border-radius: 12px;     
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 6px 12px rgba(0,0,0,0.4); 

  .poster {
    width: 100%;
    height: 400px;         
    object-fit: cover;     
  }

  .card-info {
    padding: 18px;         
    display: flex;
    flex-direction: column;
    gap: 6px;              
    flex-grow: 1;          

    p { margin: 0; }
    
    .title {
        font-size: 18px;    
        font-weight: 800;
        margin-bottom: 4px; 
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis; 
    }

    .meta {
        font-size: 14px;    
        color: #333;        
    }
    
    .btn-check {
      margin-top: auto;      
      background: black;
      color: white;
      border: none;
      padding: 10px 0;      
      border-radius: 16px;  
      font-size: 14px;      
      font-weight: bold;
      cursor: pointer;
      width: 110px;         
      align-self: center;   
      transition: background 0.2s, transform 0.1s;

      &:hover { 
        background: #333; 
        transform: scale(1.05); 
      }
    }
  }
}