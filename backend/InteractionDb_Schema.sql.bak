CREATE TABLE IF NOT EXISTS "__EFMigrationsHistory" (
    "MigrationId" character varying(150) NOT NULL,
    "ProductVersion" character varying(32) NOT NULL,
    CONSTRAINT "PK___EFMigrationsHistory" PRIMARY KEY ("MigrationId")
);

START TRANSACTION;

CREATE TABLE "InteractionLogs" (
    "LogID" integer GENERATED BY DEFAULT AS IDENTITY,
    "ActionType" text NOT NULL,
    "Timestamp" timestamp with time zone NOT NULL,
    "UserID" integer NOT NULL,
    "ContentID" integer NOT NULL,
    CONSTRAINT "PK_InteractionLogs" PRIMARY KEY ("LogID")
);

CREATE TABLE "RecommendationSessions" (
    "SessionID" integer GENERATED BY DEFAULT AS IDENTITY,
    "DateGenerated" timestamp with time zone NOT NULL,
    "AlgorithmType" text NOT NULL,
    "UserID" integer NOT NULL,
    CONSTRAINT "PK_RecommendationSessions" PRIMARY KEY ("SessionID")
);

CREATE TABLE "UserFavorites" (
    "UserID" integer NOT NULL,
    "ContentID" integer NOT NULL,
    "DateAdded" timestamp with time zone NOT NULL,
    CONSTRAINT "PK_UserFavorites" PRIMARY KEY ("UserID", "ContentID")
);

CREATE TABLE "UserRatings" (
    "UserID" integer NOT NULL,
    "ContentID" integer NOT NULL,
    "DateRated" timestamp with time zone NOT NULL,
    "Score" integer NOT NULL,
    CONSTRAINT "PK_UserRatings" PRIMARY KEY ("UserID", "ContentID")
);

CREATE TABLE "RecommendedContents" (
    "ContentID" integer NOT NULL,
    "SessionID" integer NOT NULL,
    "RankPosition" integer NOT NULL,
    "RelevanceScore" double precision NOT NULL,
    CONSTRAINT "PK_RecommendedContents" PRIMARY KEY ("SessionID", "ContentID"),
    CONSTRAINT "FK_RecommendedContents_RecommendationSessions_SessionID" FOREIGN KEY ("SessionID") REFERENCES "RecommendationSessions" ("SessionID") ON DELETE CASCADE
);

INSERT INTO "__EFMigrationsHistory" ("MigrationId", "ProductVersion")
VALUES ('20260302183521_InitialCreate', '8.0.24');

COMMIT;

